# ──────────────────────────────────────────────────────────────────────────
# IntelliCommerce + Agent Reliability Suite — environment configuration
# Copy to .env and fill in. NOTHING here is required to run the eval suite in
# mock mode (it is deterministic and free); secrets are only needed for the
# live agent and optional integrations.
# ──────────────────────────────────────────────────────────────────────────

# --- Live agent (only needed to run the REAL agent, not mock evals) ---------
GROQ_API_KEY=your_groq_api_key_here          # free at console.groq.com

# --- Reliability suite ------------------------------------------------------
# RELIABILITY_MOCK=1                          # force deterministic FakeChatModel + mock judge (CI default)
# RELIABILITY_DB=.reliability/reliability.db  # trace/eval/guardrail store (Docker: /data/reliability.db)
# AGENT_MODEL=llama-3.1-8b-instant            # model under test
# AGENT_VARIANT=base                          # fake-script variant (base | degraded) for the demo
# JUDGE_MODEL=llama-3.3-70b-versatile         # LLM-as-judge model (real mode)
# BUDGET_MAX_COST_USD=0.01                    # per-run cost ceiling (grader + circuit breaker)
# BUDGET_MAX_LATENCY_MS=15000                 # per-run latency ceiling

# --- Optional: Langfuse (LLM observability) ---------------------------------
# Create a project in the Langfuse UI (http://localhost:3001) and paste keys.
# Leave blank to use only the built-in SQLite trace store + dashboard.
# LANGFUSE_HOST=http://langfuse:3000
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# --- Optional: OpenTelemetry OTLP export (vendor-neutral) -------------------
# Point at any OTLP/HTTP collector, e.g. Langfuse v3: http://host/api/public/otel
# OTEL_EXPORTER_OTLP_ENDPOINT=
